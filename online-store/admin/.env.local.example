# Copy to .env.local (gitignored) and fill in real values.

# Super Admin login password for this dashboard.
ADMIN_DASHBOARD_PASSWORD=change-me

# Signs the session cookie — any long random string. Rotating it logs
# everyone out.
SESSION_SECRET=replace-with-a-long-random-string

# online-store/server's base URL and its ADMIN_API_KEY (must match the value
# in online-store/server/config.local.json or its ADMIN_API_KEY env var).
ONLINE_STORE_API_URL=http://localhost:4100
ONLINE_STORE_ADMIN_API_KEY=replace-with-a-long-random-string-shared-with-online-store-admin

# Public storefront base URL — used for "View Website" links and the Store
# Health panel's live reachability check.
NEXT_PUBLIC_STOREFRONT_BASE_URL=https://froshiar.store
