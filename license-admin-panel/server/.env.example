# Local dev defaults — leave NODE_ENV unset (or "development") so cookies stay
# non-Secure/Lax for plain-HTTP localhost. Leave LICENSE_PRIVATE_KEY_BASE64 and the
# Supabase vars unset locally to keep using the local key file + JSON ledger.
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_PASSWORD=change-me

# --- Production (Railway) — set these in the Railway dashboard, not here ---
# NODE_ENV=production
# CLIENT_ORIGIN=https://your-app.vercel.app,https://licenses.bexdre.com
# LICENSE_PRIVATE_KEY_BASE64=<secretKeyBase64 from scripts/license-admin/keys/private-key.json>
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role key from Supabase project settings>
