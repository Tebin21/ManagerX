{
  "expo": {
    "name": "ManagerX",
    "slug": "managerx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "managerx",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E40AF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.managerx.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photos to upload your business logo.",
        "NSCameraUsageDescription": "We need camera access to take your business logo photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#1E40AF"
      },
      "package": "com.managerx.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "expo-document-picker",
      [
        "expo-image-picker",
        {
          "photosPermission": "ManagerX needs access to your photos to upload a business logo.",
          "cameraPermission": "ManagerX needs camera access to take a business logo photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6436d21-e65c-4546-8c94-a76f2b60dc56"
      }
    }
  }
}
